{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/context-check.mjs\""
          },
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/env-verify.mjs\""
          },
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/context-cleanup.mjs\" --seed"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/lint-check.mjs\""
          },
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/context-cleanup.mjs\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/tool-offload.mjs\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/compaction.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/continuation.mjs\""
          },
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/trace-log.mjs\""
          },
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/todo-sync.mjs\""
          },
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.claude/skills/hooks-framework/scripts/quality-metric.mjs\""
          }
        ]
      }
    ]
  }
}
