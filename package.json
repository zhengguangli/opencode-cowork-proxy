{
  "name": "opencode-cowork-proxy",
  "version": "2.1.3",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run scripts/build-entry.ts",
    "build:binary": "bun build --compile --bytecode --outfile ./dist/opencode-cowork-proxy scripts/build-entry.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit && echo \"\u2705 TypeScript: no errors\"",
    "deploy": "bunx wrangler deploy",
    "build": "bun build ./src/index.ts --outdir ./dist --minify"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "description": "Bidirectional AI API translation gateway. Anthropic\u2194OpenAI format bridge.",
  "dependencies": {
    "hono": "^4.12.17",
    "zod": "^4.4.3"
  }
}