{
  "name": "opencode-cowork-proxy",
  "version": "2.1.5",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run scripts/build-entry.ts",
    "build:binary": "bun build --compile --bytecode --outfile ./dist/opencode-cowork-proxy scripts/build-entry.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit && echo \"✅ TypeScript: no errors\"",
    "deploy": "bunx wrangler deploy",
    "build": "bun build ./src/index.ts --outdir ./dist --minify"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "description": "Bidirectional AI API translation gateway. Anthropic↔OpenAI format bridge.",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@sentry/node": "^10.58.0",
    "hono": "^4.12.17",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "pino-roll": "^4.0.0",
    "zod": "^4.4.3"
  }
}